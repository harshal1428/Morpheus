# ============================================================
# PROJECTION ENGINE - ENVIRONMENT CONFIGURATION
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env to version control
#
# To set up:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials
# 3. Run the application
# ============================================================

# Mistral AI Configuration
# Choose between local Ollama or cloud API

# Use Local Ollama Installation
MISTRAL_USE_LOCAL=True

# Local Ollama Settings (if MISTRAL_USE_LOCAL=True)
MISTRAL_LOCAL_URL=http://localhost:11434
MISTRAL_LOCAL_MODEL=mistral:latest

# Cloud API Key (if MISTRAL_USE_LOCAL=False)
# Leave empty if using local Ollama
# Get your key from: https://console.mistral.ai
MISTRAL_API_KEY=

# Database Configuration
# Path to SQLite database file
DATABASE_URL=sqlite:///./projection.db

# Server Configuration
HOST=127.0.0.1
PORT=8001

# Debug Mode
# Set to False in production
DEBUG=True

# Performance Tuning
# Cache TTL for forecast results (in minutes)
FORECAST_CACHE_TTL_MINUTES=60

# Monte Carlo Simulations
# Number of simulations for probabilistic forecasting
MC_SIMULATIONS=1000

# Optional: Supabase Integration
# Uncomment if using Supabase as backend
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_API_KEY=your-supabase-api-key
