# ============================================================
# MORPHEUS BACKEND - ENVIRONMENT CONFIGURATION
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env to version control
#
# To set up:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials
# 3. Run the application
# ============================================================

# Database Configuration
# Path to SQLite database file
DATABASE_URL=sqlite:///./data/finance.db

# Security
# Generate a strong secret key for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# Model Confidence
# Threshold for ML model predictions (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.85

# OCR Configuration (Windows Path)
# Path to Tesseract OCR executable
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Debug Mode
# Set to False in production
DEBUG=True

# Application Info
APP_NAME=Personal Finance Manager
APP_VERSION=1.0.0

# Optional: Supabase Integration
# Uncomment and fill if using Supabase backend
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_API_KEY=your-supabase-api-key
